rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'createdAt',
          'difficulty',
          'finalScore',
          'hintsUsed',
          'mistakes',
          'playerName',
          'timeInSeconds',
          'uid'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.playerName is string
        && request.resource.data.difficulty in ['easy', 'medium', 'hard']
        && request.resource.data.finalScore is int
        && request.resource.data.hintsUsed is int
        && request.resource.data.mistakes is int
        && request.resource.data.timeInSeconds is int
        && request.resource.data.finalScore >= 0
        && request.resource.data.hintsUsed >= 0
        && request.resource.data.mistakes >= 0
        && request.resource.data.timeInSeconds >= 0
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}
